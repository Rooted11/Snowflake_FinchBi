{
  "ConnectionStrings": {
    "_comment": "Real value is injected via the ConnectionStrings__Neon env var (Render) or appsettings.Development.json (local, gitignored). Do not commit credentials here.",
    "Neon": "Host=YOUR-NEON-HOST.neon.tech;Database=neondb;Username=neondb_owner;Password=SET_VIA_ENV_OR_DEV_SETTINGS;SSL Mode=Require;Trust Server Certificate=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Connectors": {
    "SyncIntervalMinutes": 360,
    "Bloomerang": {
      "Enabled": false,
      "ApiKey": "",
      "BaseUrl": "https://api.bloomerang.co/v2"
    }
  },
  "AllowedHosts": "*"
}
